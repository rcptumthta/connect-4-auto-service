{
  "version": "1.0.0",
  "name": "connect-4-auto-service",
  "description": "Web Service APIs for Connect4Auto platform",
  "author": {
    "name": "Ratchapol Thongta",
    "email": "rcptum.thta@outlook.com",
    "url": "https://github.com/rcptumthta"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rcptumthta/connect-4-auto-service.git"
  },
  "bugs": {
    "url": "https://github.com/rcptumthta/connect-4-auto-service/issues"
  },
  "scripts": {
    "lint": "eslint . --ext .js,.json,.json5,.jsonc,.jsonl,.ts",
    "lint:fix": "eslint . --ext .js,.json,.json5,.jsonc,.jsonl,.ts --fix",
    "build": "cross-env NODE_ENV=development nest build",
    "build:staging": "cross-env NODE_ENV=staging nest build",
    "build:production": "cross-env NODE_ENV=production nest build",
    "build:test": "cross-env NODE_ENV=test nest build",
    "build:ci": "cross-env NODE_ENV=ci nest build",
    "start": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "cross-env NODE_ENV=development jest",
    "test:unit-watch": "cross-env NODE_ENV=development jest --watch",
    "test:unit-coverage": "cross-env NODE_ENV=development jest --coverage",
    "test:unit-ci": "cross-env NODE_ENV=ci jest",
    "test:unit-coverage-ci": "cross-env NODE_ENV=ci jest --coverage",
    "test:e2e": "cross-env NODE_ENV=development jest ---config ./e2e/jest-e2e.config.ts",
    "test:e2e-ci": "cross-env NODE_ENV=ci jest --config ./e2e/jest-e2e.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.4.4",
    "@nestjs/core": "10.4.4",
    "@nestjs/cqrs": "10.2.7",
    "@nestjs/platform-fastify": "10.4.4",
    "fastify": "5.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@automock/adapters.nestjs": "2.1.0",
    "@automock/jest": "2.1.0",
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/eslint": "9.6.1",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/jest": "29.5.13",
    "@types/node": "22.7.5",
    "@types/source-map-support": "0.5.10",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "copy-webpack-plugin": "12.0.2",
    "cross-env": "7.0.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jsonc": "2.16.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-promise": "7.1.0",
    "eslint-plugin-sonarjs": "2.0.3",
    "eslint-plugin-unicorn": "56.0.0",
    "eslint-plugin-unused-imports": "3.2.0",
    "eslint-webpack-plugin": "4.2.0",
    "jest": "29.7.0",
    "jsonc-eslint-parser": "2.4.0",
    "prettier": "3.3.3",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "terser-webpack-plugin": "5.3.10",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "webpack": "5.95.0"
  },
  "private": true,
  "engines": {
    "node": "^18 || ^20",
    "npm": ">=10"
  }
}
