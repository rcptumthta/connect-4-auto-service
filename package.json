  },
  "bugs": {
    "url": "https://github.com/rcptumthta/connect-4-auto-service/issues"
  },
  "scripts": {
    "lint": "eslint . --ext .json,.json5,.jsonc,.jsonl",
    "lint:fix": "eslint . --ext .json,.json5,.jsonc,.jsonl --fix",
    "build": "cross-env NODE_ENV=development nest build",
    "build:staging": "cross-env NODE_ENV=staging nest build",
    "build:production": "cross-env NODE_ENV=production nest build",
    "build:test": "cross-env NODE_ENV=test nest build",
    "build:ci": "cross-env NODE_ENV=ci nest build",
    "start": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch"
  },
  "dependencies": {
    "@nestjs/common": "10.4.4",
    "@nestjs/core": "10.4.4",
    "@nestjs/cqrs": "10.2.7",
    "@nestjs/platform-fastify": "10.4.4",
    "fastify": "5.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@types/eslint": "9.6.1",
    "@types/node": "22.7.5",
    "cross-env": "7.0.3",
    "eslint": "8.57.1",
    "eslint-plugin-jsonc": "2.16.0",
    "jsonc-eslint-parser": "2.4.0",
    "typescript": "5.3.3"
  },
  "private": true,
  "engines": {
    "node": "^18 || ^20",
    "npm": ">=10"
  }
}
